{
  "name": "moviepedia-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @movie/web",
    "dev:mobile": "npm run start -w @movie/mobile",
    "build:web": "npm run build -w @movie/web",
    "capture:portfolio": "node scripts/capture-portfolio-snapshots.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
